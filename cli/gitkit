#!/usr/bin/env bash
# gitkit — simplified, svn-style git workflow tool.
#
# Commands: st · ci · up · diff · reset · exp · log   (see `gitkit help`).
# Pure bash, zero deps, targets git 1.8.3.1 on CentOS 7. Put this dir on PATH
# (or symlink `gitkit` into ~/bin) and run `gitkit <command>`.
#
# This file only resolves lib/, sources the modules, and dispatches; each
# command lives in lib/<name>.sh and help text in lib/help.sh.

# Re-exec under bash if started via `sh gitkit` (the scripts use process
# substitution + mapfile, which POSIX /bin/sh does not support).
if [ -z "${BASH_VERSION:-}" ]; then exec bash "$0" "$@"; fi

# NOTE: no `set -u`. bash 4.2 (CentOS 7) wrongly reports an empty array
# expansion `"${arr[@]}"` as an unbound variable under nounset (bug fixed in
# bash 4.4); this code uses empty arrays everywhere, so nounset is unusable.
set -o pipefail

# Resolve our own location (follow symlinks) so lib/ is found from anywhere.
_src="$0"
if command -v readlink >/dev/null 2>&1; then
  _resolved="$(readlink -f "$_src" 2>/dev/null)" && [ -n "$_resolved" ] && _src="$_resolved"
fi
GK_HOME="$(cd "$(dirname "$_src")" && pwd)"
GK_LIB="$GK_HOME/lib"

# shellcheck source=lib/common.sh
. "$GK_LIB/common.sh"
. "$GK_LIB/help.sh"
. "$GK_LIB/st.sh"
. "$GK_LIB/ci.sh"
. "$GK_LIB/up.sh"
. "$GK_LIB/diff.sh"
. "$GK_LIB/reset.sh"
. "$GK_LIB/exp.sh"
. "$GK_LIB/log.sh"

main() {
  local cmd="${1:-}"
  [ $# -gt 0 ] && shift

  # `gitkit <command> -h|--help` -> that command's detailed help.
  case "${1:-}" in -h|--help) gk_help "$cmd"; return 0;; esac

  case "$cmd" in
    st)            gk_cmd_st    "$@";;
    ci)            gk_cmd_ci    "$@";;
    up)            gk_cmd_up    "$@";;
    diff)          gk_cmd_diff  "$@";;
    reset)         gk_cmd_reset "$@";;
    exp)           gk_cmd_exp   "$@";;
    log)           gk_cmd_log   "$@";;
    help)          gk_help "${1:-}";;        # gitkit help [command]
    -h|--help|"")  gk_usage;;
    -V|--version)  printf 'gitkit %s\n' "$GK_VERSION";;
    *) gk_err "unknown command: $cmd"; printf 'try: gitkit help\n' >&2; exit 2;;
  esac
}

main "$@"
