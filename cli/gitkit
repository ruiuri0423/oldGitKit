#!/usr/bin/env bash
# gitkit — simplified bash git helper (ci / push / mg / diff / reset).
#
# Pure bash, zero deps, targets git 1.8.3.1 on CentOS 7. Put this dir on PATH
# (or symlink `gitkit` into ~/bin) and run `gitkit <command>`.

# Re-exec under bash if started via `sh gitkit` (the scripts use process
# substitution + mapfile, which POSIX /bin/sh does not support).
if [ -z "${BASH_VERSION:-}" ]; then exec bash "$0" "$@"; fi

# NOTE: no `set -u`. bash 4.2 (CentOS 7) wrongly reports an empty array
# expansion `"${arr[@]}"` as an unbound variable under nounset (bug fixed in
# bash 4.4); this code uses empty arrays everywhere, so nounset is unusable.
set -o pipefail

# Resolve our own location (follow symlinks) so lib/ is found from anywhere.
_src="$0"
if command -v readlink >/dev/null 2>&1; then
  _resolved="$(readlink -f "$_src" 2>/dev/null)" && [ -n "$_resolved" ] && _src="$_resolved"
fi
GK_HOME="$(cd "$(dirname "$_src")" && pwd)"
GK_LIB="$GK_HOME/lib"

# shellcheck source=lib/common.sh
. "$GK_LIB/common.sh"
. "$GK_LIB/st.sh"
. "$GK_LIB/ci.sh"
. "$GK_LIB/up.sh"
. "$GK_LIB/diff.sh"
. "$GK_LIB/reset.sh"
. "$GK_LIB/exp.sh"
. "$GK_LIB/log.sh"

gk_usage() {
  cat >&2 <<'EOF'
gitkit — simplified git workflow tool

Usage: gitkit <command>

  st      git status; `gitkit st -uq` hides untracked (modified/staged only)
  ci      the combined flow: pick U/M files -> add -> commit -> pick a branch
          -> stash leftover edits -> fetch + merge that branch in -> stash pop
          -> push current HEAD to that branch (with conflict handling)
  up      update the current branch from its upstream (no commit/push):
          stash leftover edits -> fetch + merge upstream -> stash pop
  diff    pick U/M/S files and open each in git's configured difftool
  reset   unstage files, or reset the branch to a commit (soft/mixed/hard)
  exp     export a tracked folder without .git: `gitkit exp <path> [dest]`
          (git archive HEAD <path> -> unzip into dest/<path>)
  log     history with changed paths (svn log -v style):
          `gitkit log [limit] [path]`  ->  git log --name-status

Conflict options: tf=their full  mf=mine full  tc=their conflict  mc=mine conflict
                  e=edit(git mergetool)  r=resolved  a=abort
EOF
}

main() {
  local cmd="${1:-}"
  [ $# -gt 0 ] && shift
  case "$cmd" in
    st)    gk_cmd_st "$@";;
    ci)    gk_cmd_ci "$@";;
    up)    gk_cmd_up "$@";;
    diff)  gk_cmd_diff "$@";;
    reset) gk_cmd_reset "$@";;
    exp)   gk_cmd_exp "$@";;
    log)   gk_cmd_log "$@";;
    ""|-h|--help|help) gk_usage;;
    *) gk_err "未知指令: $cmd"; gk_usage; exit 2;;
  esac
}

main "$@"
